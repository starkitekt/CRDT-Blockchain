# HoneyTRACE Environment Variables
# Copy this file to .env.local and fill in the values.

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/honeytrace
JWT_SECRET=change-me-local

# Frontend wallet contract address (set by scripts/contracts/sync-abi.js)
NEXT_PUBLIC_HONEYTRACE_CONTRACT=

# Local and production chain RPC endpoints
LOCAL_RPC_URL=http://127.0.0.1:8545
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
BASE_SEPOLIA_RPC_URL=

# Relayer credentials for backend writes
# Local default uses first hardhat account key.
DEPLOYER_PRIVATE_KEY=
BLOCKCHAIN_RELAYER_PRIVATE_KEY=
HONEYTRACE_CONTRACT_ADDRESS=

# Frontend warning threshold
NEXT_PUBLIC_MIN_BALANCE_ETH=0.002
