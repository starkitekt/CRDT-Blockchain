# HoneyTRACE Environment Variables
# Copy this file to .env.local and fill in the values.

# ── Blockchain ────────────────────────────────────────────────────────────────
# Deployed HoneyTraceRegistry.sol contract address on your target network.
# Polygon PoS (chainId 137) is recommended for production (low gas fees).
# Leave empty to disable on-chain features (app still runs in demo mode).
NEXT_PUBLIC_HONEYTRACE_CONTRACT=0x

# ── Network / RPC (optional) ──────────────────────────────────────────────────
# Public RPC URL for read-only calls (no wallet required).
# Defaults to the injected MetaMask provider when not set.
# NEXT_PUBLIC_RPC_URL=https://polygon-rpc.com

# ── Auth (replace in production) ─────────────────────────────────────────────
# The current auth route (/api/auth) accepts any non-empty credentials.
# In production, replace with a real secret and user store.
# AUTH_SECRET=change-me
