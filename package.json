{
  "name": "honeytrace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "seed": "tsx scripts/seed.ts --reset",
    "chain:compile": "hardhat compile",
    "chain:test": "hardhat test",
    "chain:node": "hardhat node --hostname 127.0.0.1 --port 8545",
    "chain:deploy:local": "hardhat run scripts/contracts/deploy.js --network localhost",
    "chain:deploy:base": "hardhat run scripts/contracts/deploy.js --network baseSepolia",
    "chain:sync": "node scripts/contracts/sync-abi.js",
    "db:up": "docker run -d --rm --name honeytrace-mongo -p 27017:27017 mongo:7",
    "db:down": "docker stop honeytrace-mongo",
    "local:up": "bash scripts/localhost.sh up",
    "local:down": "bash scripts/localhost.sh down",
    "local:check": "bash scripts/localhost.sh check",
    "net:local": "bash scripts/network.sh local",
    "net:base": "bash scripts/network.sh base",
    "net:deploy:local": "bash scripts/network.sh deploy:local",
    "net:deploy:base": "bash scripts/network.sh deploy:base",
    "net:deploy:both": "bash scripts/network.sh deploy:both",
    "net:status": "bash scripts/network.sh status",
    "prod:push": "bash scripts/push-local-to-prod.sh",
    "prod:push:dry": "bash scripts/push-local-to-prod.sh --dry-run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:all": "npm run chain:test && npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "@carbon/icons-react": "^11.76.0",
    "@carbon/react": "^1.103.0",
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^3.0.3",
    "ethers": "^6.16.0",
    "html5-qrcode": "^2.3.8",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "mongoose": "^9.3.2",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "sass": "^1.98.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.0",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chai": "^4.5.0",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "hardhat": "^2.26.5",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
